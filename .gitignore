# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/

# ── Entornos virtuales ────────────────────────────────────────────────────────
venv/
env/
.env
.venv/
.venv_build/
.venv_nuitka/

# ── Build artifacts (PyInstaller) ─────────────────────────────────────────────
build/
*.spec.bak

# ── Build artifacts (Nuitka) ──────────────────────────────────────────────────
.nuitka_build/
*.build/
*.dist/
*.onefile-build/

# ── Distribución compilada ────────────────────────────────────────────────────
# Los ejecutables y carpetas de distribución no se verscionan;
# se generan con build_nuitka.ps1 o build_exe.ps1
dist/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.cursor/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Archivos temporales de PDFlex ─────────────────────────────────────────────
# Directorio de descarga del auto-updater (se crea en runtime)
# %TEMP%/PDFlex/updates/ — no está en el proyecto, solo referencia
